{
    "editor.fontFamily": "'JetBrains Mono', Consolas, 'Courier New', monospace",
    "editor.fontLigatures": true,
    "editor.fontSize": 13,
    "editor.lineHeight": 24,
    "explorer.compactFolders": false,
    // Meilleure lisibilité des espaces
    "editor.renderWhitespace": "boundary",
    "editor.renderControlCharacters": false,
    // Affichage du guide d'indentation
    "editor.guides.indentation": true,
    // Meilleure expérience de terminal
    "terminal.integrated.fontFamily": "'JetBrains Mono', monospace",
    "terminal.integrated.fontSize": 13,
    // Réduction de la fatigue visuelle
    "workbench.colorTheme": "Tokyo Night",
    "workbench.colorCustomizations": {
        "[Tokyo Night]": {
            "editor.selectionBackground": "#3D59A1",
            "editor.selectionHighlightBackground": "#0048ff76",
            "terminal.foreground": "#00a838",
            "terminal.background": "#000000",
            "editor.lineHighlightBackground": "#2c3040",
            "editorCursor.foreground": "#ffcc00"
        }
    },
    // Supprime les notifications trop intrusives
    "telemetry.telemetryLevel": "off",
    // Auto save
    "files.autoSave": "afterDelay",
    // Meilleure gestion du formatage (si tu utilises Prettier)
    "editor.formatOnSave": true,
    "editor.tabSize": 2,
    "editor.insertSpaces": true,
    "[javascript]": {
        "editor.formatOnSave": true
    },
    "[php]": {
        "editor.formatOnSave": true
    },
    "[json]": {
        "editor.quickSuggestions": {
            "strings": true
        }
    },
    "workbench.iconTheme": "material-icon-theme",
    "remote.SSH.remotePlatform": {
        "stagiairesma_v3": "linux",
        "stagiairesma_v3_ovh": "linux"
    },
    "[typescriptreact]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[typescript]": {
        "editor.defaultFormatter": "esbenp.prettier-vscode"
    },
    "[css]": {
        "editor.defaultFormatter": "vscode.css-language-features"
    },
    "typescript.updateImportsOnFileMove.enabled": "always",
    "[html]": {
        "editor.defaultFormatter": "vscode.html-language-features"
    },
    "github.copilot.nextEditSuggestions.enabled": true,
    "gitlens.ai.model": "vscode",
    "[jsonc]": {
        "editor.defaultFormatter": "vscode.json-language-features"
    },
    "gitlens.rebaseEditor.ordering": "asc",
    "chat.extensionUnification.enabled": false,
    "chat.agent.maxRequests": 100,
    "workbench.editor.empty.hint": "hidden",
    "diffEditor.maxComputationTime": 0,
    "git.autofetch": true,
    "dart.flutterSdkPath": "C:\\flutter",
    "terminal.integrated.initialHint": false,
    "claudeCode.preferredLocation": "panel",
    "git.enableSmartCommit": true,
    "chat.viewSessions.orientation": "stacked"
}